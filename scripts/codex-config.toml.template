# Codex config: base_url points to codex-proxy (converts to llama-server). Proxy fixes "tool type must be 'function'" for Codex.
model = "__MODEL_NAME__"
model_provider = "local"

[model_providers.local]
name = "llama.cpp"
base_url = "http://127.0.0.1:__PROXY_PORT__/v1"
wire_api = "responses"

[profiles.local]
model = "__MODEL_NAME__"
model_provider = "local"
web_search = "disabled"
